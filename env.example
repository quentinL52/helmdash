# ==========================================
# AI PROVIDERS (At least one required)
# ==========================================
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GOOGLE_AI_API_KEY="..."  # Gemini
MISTRAL_API_KEY="..."

# ==========================================
# ENCRYPTION (Required for API key encryption)
# ==========================================
MASTER_ENCRYPTION_KEY="generate-with: openssl rand -base64 32"  # 32 bytes base64

# ==========================================
# RATE LIMITING (Upstash Redis)
# ==========================================
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# Alternative: Vercel KV
# KV_REST_API_URL="..."
# KV_REST_API_TOKEN="..."

# ==========================================
# STRIPE (Billing)
# ==========================================
STRIPE_SECRET_KEY="sk_live_..."  # or sk_test_...
STRIPE_PUBLISHABLE_KEY="pk_live_..."  # or pk_test_...
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# Stripe Price IDs (cohort pricing)
STRIPE_PRICE_FOUNDER_MONTHLY="price_..."
STRIPE_PRICE_CORE_MONTHLY="price_..."
STRIPE_PRICE_COMPLETE_MONTHLY="price_..."

# Cron job security
CRON_SECRET="generate-secure-random-string"

# ==========================================
# COMPOSIO (Integrations)
# ==========================================
COMPOSIO_API_KEY="your-composio-key"

# ==========================================
# EMAIL (Resend)
# ==========================================
RESEND_API_KEY="re_..."
EMAIL_FROM="Helmdash <noreply@helmdash.app>"

# ==========================================
# OBSERVABILITY
# ==========================================
SENTRY_DSN="https://...@sentry.io/..."
NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."
POSTHOG_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_KEY="phc_..."

# ==========================================
# APP CONFIG
# ==========================================
NEXT_PUBLIC_APP_URL="https://helmdash.app"
NEXT_PUBLIC_APP_NAME="Helmdash"
HERMES_API_KEY="generate-secure-random-string"  # For external agents

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_SUB_AGENTS="true"
ENABLE_STRIPE_SYNC="true"
ENABLE_WEB_SEARCH="false"
ENABLE_MEMORY_GRAPH="true"
