# AirH Founder OS - Environment Variables Template
# Copiez ce fichier vers .env.local et remplissez les valeurs

# ==========================================
# DATABASE (Supabase / PostgreSQL + pgvector)
# ==========================================
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# ==========================================
# SUPABASE (Auth + Database + Realtime + Vault)
# ==========================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"  # Server-side only

# ==========================================
# AI PROVIDERS (Au moins un requis)
# ==========================================
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GOOGLE_AI_API_KEY="..."  # Gemini
MISTRAL_API_KEY="..."

# ==========================================
# ENCRYPTION (Obligatoire pour chiffrement clés API)
# ==========================================
MASTER_ENCRYPTION_KEY="generate-with: openssl rand -base64 32"  # 32 bytes base64

# ==========================================
# RATE LIMITING (Upstash Redis)
# ==========================================
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# Alternative: Vercel KV (si pas Upstash)
# KV_REST_API_URL="..."
# KV_REST_API_TOKEN="..."

# ==========================================
# STRIPE (Billing)
# ==========================================
STRIPE_SECRET_KEY="sk_live_..."  # ou sk_test_...
STRIPE_PUBLISHABLE_KEY="pk_live_..."  # ou pk_test_...
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# Stripe Price IDs (à créer dans Dashboard Stripe)
STRIPE_PRICE_STARTER_YEARLY="price_..."
STRIPE_PRICE_GROWTH_YEARLY="price_..."
STRIPE_PRICE_SCALE_YEARLY="price_..."

# ==========================================
# COMPOSIO (Intégrations 100+ outils)
# ==========================================
COMPOSIO_API_KEY="your-composio-key"

# ==========================================
# EMAIL (Resend)
# ==========================================
RESEND_API_KEY="re_..."
EMAIL_FROM="AirH Founder OS <noreply@yourdomain.com>"

# ==========================================
# OBSERVABILITY
# ==========================================
SENTRY_DSN="https://...@sentry.io/..."
NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."
POSTHOG_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_KEY="phc_..."

# ==========================================
# APP CONFIG
# ==========================================
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
NEXT_PUBLIC_APP_NAME="AirH Founder OS"
HERMES_API_KEY="generate-secure-random-string"  # Pour agents externes

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_SUB_AGENTS="true"
ENABLE_STRIPE_SYNC="true"
ENABLE_WEB_SEARCH="false"  # Nécessite Composio/SerpAPI
ENABLE_MEMORY_GRAPH="true"